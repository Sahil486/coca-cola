<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тренажер ОЭЗ Алабуга + Теория</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, sans-serif; }
        body { background-color: #0f1115; color: #e3e6eb; padding: 15px; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        .wrapper { width: 100%; max-width: 720px; background: #161920; border-radius: 16px; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.6); border: 1px solid #252a37; }
        h1 { font-size: 20px; color: #ffffff; text-align: center; margin-bottom: 5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
        .subtitle { text-align: center; color: #7c8596; font-size: 12px; margin-bottom: 15px; }
        
        /* Модуль Помодоро */
        .pomodoro-bar { background: #1e222d; border: 1px solid #2d3446; padding: 10px 15px; border-radius: 12px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
        .pomo-title { font-size: 12px; font-weight: 600; color: #9aa5b9; display: flex; align-items: center; gap: 6px; }
        .pomo-status { width: 8px; height: 8px; border-radius: 5px; background: #10b981; display: inline-block; }
        .pomo-status.work { background: #ef4444; box-shadow: 0 0 8px #ef4444; }
        .pomo-status.break { background: #10b981; box-shadow: 0 0 8px #10b981; }
        .pomo-time { font-family: monospace; font-size: 16px; font-weight: 700; color: #ffffff; }
        .pomo-btn { padding: 4px 10px; background: #252a37; border: 1px solid #374151; color: #e3e6eb; border-radius: 6px; font-size: 11px; cursor: pointer; font-weight: 600; }

        .tabs { display: flex; gap: 5px; margin-bottom: 20px; flex-wrap: wrap; justify-content: center; }
        .tab-btn { flex: 1; min-width: 110px; padding: 10px 5px; background: #202531; border: 1px solid #2d3446; color: #9aa5b9; border-radius: 10px; cursor: pointer; font-weight: 600; font-size: 12px; transition: all 0.2s; text-align: center; }
        .tab-btn.active { background: #0066FF; color: #ffffff; border-color: #0066FF; box-shadow: 0 4px 12px rgba(0,102,255,0.3); }
        .panel { display: none; }
        .panel.active { display: block; }
        
        .matrix-row { background: #1e222d; border: 1px solid #2d3446; padding: 12px; border-radius: 8px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
        .matrix-step { font-weight: 700; color: #0066FF; min-width: 85px; font-size: 13px; }
        .matrix-hidden { background: #252a37; color: #5b6577; cursor: pointer; padding: 8px 12px; border-radius: 6px; border: 1px dashed #0066FF; transition: all 0.2s; width: 85%; font-size: 13px; text-align: left; user-select: none; }
        .matrix-hidden:hover { background: #2a3142; color: #9aa5b9; }
        .matrix-hidden.revealed { background: transparent; color: #e3e6eb; border: 1px solid transparent; cursor: default; }
        .section-title { font-size: 13px; font-weight: 700; color: #ffffff; margin: 20px 0 10px 0; text-transform: uppercase; border-bottom: 1px solid #2d3446; padding-bottom: 6px; width: 100%; text-align: left; }

        .card-box { background: #1e222d; border: 1px solid #2d3446; border-radius: 14px; min-height: 160px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 25px; cursor: pointer; margin-bottom: 15px; position: relative; text-align: center; }
        .card-box .type { position: absolute; top: 12px; font-size: 11px; font-weight: 700; color: #0066FF; text-transform: uppercase; }
        .card-text { font-size: 15px; font-weight: 500; line-height: 1.5; color: #ffffff; }
        .hint { font-size: 12px; color: #5b6577; margin-top: 15px; }
        .option-btn { width: 100%; padding: 13px; background: #1e222d; border: 1px solid #2d3446; color: #e3e6eb; border-radius: 10px; text-align: left; margin-bottom: 10px; cursor: pointer; font-size: 13px; font-weight: 500; transition: background 0.2s; line-height: 1.4; }
        .option-btn:hover { background: #252a37; }
        .option-btn.correct { background: #10b981 !important; border-color: #10b981; color: white; }
        .option-btn.wrong { background: #ef4444 !important; border-color: #ef4444; color: white; }
        
        /* Теоретический блок прямо в тесте */
        .theory-box { background: #1a2436; border: 1px solid #0066FF; border-radius: 10px; padding: 15px; margin-top: 15px; display: none; text-align: left; font-size: 13px; line-height: 1.5; color: #e3e6eb; }
        .theory-title { font-weight: 700; color: #38bdf8; margin-bottom: 6px; text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px; }
        .theory-scheme-img { width: 100%; border-radius: 8px; margin-top: 10px; border: 1px solid #2d3446; cursor: zoom-in; }
        .img-modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 2000; align-items: center; justify-content: center; padding: 20px; }
        .img-modal.open { display: flex; }
        .img-modal img { max-width: 100%; max-height: 100%; border-radius: 8px; }

        .nav-layout { display: flex; gap: 10px; margin-top: 15px; }
        .action-btn { flex: 1; padding: 12px; background: #202531; border: 1px solid #2d3446; color: white; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 14px; }
        .action-btn.primary { background: #0066FF; border-color: #0066FF; }
        .action-btn.theory-btn { background: #2d3548; border-color: #4b5563; color: #9aa5b9; }
        .score-counter { text-align: center; font-size: 12px; color: #7c8596; margin-top: 10px; }
        
        .results-card { background: #1e222d; border: 1px solid #2d3446; border-radius: 12px; padding: 20px; margin-top: 15px; }
        .results-header { font-size: 18px; font-weight: 700; color: #ffffff; margin-bottom: 10px; text-align: center; }
        .wrong-item { background: #251c22; border-left: 4px solid #ef4444; padding: 10px; margin-bottom: 8px; border-radius: 4px; font-size: 13px; text-align: left; }
        .wrong-q { font-weight: 600; color: #fca5a5; margin-bottom: 3px; }
        .wrong-a { color: #10b981; font-weight: 500; }
        .feynman-answer { background: #1a2721; border: 1px solid #10b981; border-radius: 10px; padding: 15px; margin-top: 15px; display: none; text-align: left; font-size: 14px; line-height: 1.5; color: #e3e6eb; }

        /* ИГРА: ПОДБОР */
        .match-timer { font-size: 32px; font-weight: 700; color: #ffffff; text-align: center; margin-bottom: 15px; font-variant-numeric: tabular-nums; }
        .match-board { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
        @media (min-width: 480px) { .match-board { grid-template-columns: repeat(3, 1fr); } }
        .match-card { background: #1e222d; border: 2px solid #2d3446; border-radius: 8px; padding: 12px; font-size: 12px; font-weight: 500; color: #e3e6eb; text-align: center; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; min-height: 110px; user-select: none; line-height: 1.4; overflow: hidden; }
        .match-card:hover { background: #252a37; }
        .match-card.selected { border-color: #0066FF; background: #202531; box-shadow: 0 0 10px rgba(0,102,255,0.4); }
        .match-card.wrong { border-color: #ef4444; background: #3b1f24; animation: shake 0.4s; }
        .match-card.hidden { opacity: 0; visibility: hidden; pointer-events: none; transform: scale(0.9); transition: all 0.3s; }
        @keyframes shake { 0%, 100% {transform: translateX(0);} 25% {transform: translateX(-6px);} 50% {transform: translateX(6px);} 75% {transform: translateX(-6px);} }

        /* ЧАТ-АССИСТЕНТ */
        .chat-fab { position: fixed; bottom: 20px; right: 20px; width: 56px; height: 56px; border-radius: 50%; background: #0066FF; color: white; display: flex; align-items: center; justify-content: center; font-size: 26px; cursor: pointer; box-shadow: 0 6px 20px rgba(0,102,255,0.5); z-index: 999; border: none; transition: transform 0.2s; }
        .chat-fab:hover { transform: scale(1.08); }
        .chat-panel { position: fixed; bottom: 90px; right: 20px; width: 320px; max-width: calc(100vw - 30px); height: 440px; max-height: calc(100vh - 120px); background: #161920; border: 1px solid #2d3446; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.7); display: none; flex-direction: column; overflow: hidden; z-index: 1000; }
        .chat-panel.open { display: flex; }
        .chat-header { background: #0066FF; color: white; padding: 12px 14px; font-weight: 700; font-size: 13px; display: flex; justify-content: space-between; align-items: center; }
        .chat-close { cursor: pointer; font-size: 18px; line-height: 1; opacity: 0.85; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; background: #0f1115; }
        .chat-msg { max-width: 85%; padding: 9px 12px; border-radius: 10px; font-size: 13px; line-height: 1.4; }
        .chat-msg.user { align-self: flex-end; background: #0066FF; color: white; }
        .chat-msg.bot { align-self: flex-start; background: #1e222d; color: #e3e6eb; border: 1px solid #2d3446; white-space: pre-wrap; }
        .chat-msg.bot.loading { color: #7c8596; font-style: italic; }
        .chat-input-row { display: flex; border-top: 1px solid #2d3446; padding: 8px; gap: 6px; background: #161920; }
        .chat-input-row input { flex: 1; background: #1e222d; border: 1px solid #2d3446; color: #e3e6eb; border-radius: 8px; padding: 9px 10px; font-size: 13px; outline: none; }
        .chat-input-row button { background: #0066FF; border: none; color: white; border-radius: 8px; padding: 0 14px; font-weight: 700; cursor: pointer; font-size: 13px; }
        .chat-hint { font-size: 10px; color: #5b6577; text-align: center; padding: 4px 0 6px; }
    </style>
</head>
<body>

    <div class="wrapper">
        <h1>ОЭЗ Алабуга ULTIMATE v5</h1>
        <div class="subtitle">Интервалы • Режим Интерактивной Теории • Подбор • Помодоро</div>

        <div class="pomodoro-bar">
            <div class="pomo-title">
                <span id="pomo-dot" class="pomo-status break"></span>
                <span id="pomo-label">Помодоро: Готов к работе</span>
            </div>
            <div class="pomo-time" id="pomo-display">50:00</div>
            <button class="pomo-btn" id="pomo-toggle" onclick="togglePomodoro()">Старт</button>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('cards-tab', this)">Карточки</button>
            <button class="tab-btn" onclick="switchTab('test-tab', this)">Тест</button>
            <button class="tab-btn" onclick="switchTab('match-tab', this)">Подбор</button>
            <button class="tab-btn" onclick="switchTab('feynman-tab', this)">Фейнман</button>
            <button class="tab-btn" onclick="switchTab('matrix-tab', this)">Таблицы</button>
        </div>

        <!-- КАРТОЧКИ -->
        <div id="cards-tab" class="panel active">
            <div class="card-box" onclick="flipCard()">
                <div class="type" id="card-type">Вопрос</div>
                <div class="card-text" id="card-main">Загрузка...</div>
                <div class="hint">Кликните на карточку, чтобы перевернуть</div>
            </div>
            <div class="nav-layout">
                <button class="action-btn" onclick="prevCard()">Назад</button>
                <button class="action-btn primary" onclick="nextCard()">Дальше</button>
            </div>
            <div class="score-counter" id="card-index">0 / 0</div>
        </div>

        <!-- ТЕСТ -->
        <div id="test-tab" class="panel">
            <div id="test-gameplay">
                <div class="card-box" style="min-height:90px; cursor:default;">
                    <div class="card-text" id="test-question">Загрузка...</div>
                </div>
                <div id="test-options"></div>
                
                <!-- Блок разворачиваемой теории -->
                <div class="theory-box" id="test-theory-box">
                    <div class="theory-title">📘 База знаний (Официальная Теория):</div>
                    <div id="test-theory-text"></div>
                    <img id="test-theory-img" class="theory-scheme-img" style="display:none;" />
                </div>

                <div class="nav-layout">
                    <button class="action-btn theory-btn" id="dont-know-btn" onclick="triggerDontKnowTheory()">Не знаю ответа (Учить)</button>
                    <button class="action-btn primary" id="next-test-btn" onclick="nextTestQuestion()">Следующий вопрос</button>
                </div>
                <div class="score-counter" id="test-index">Загрузка...</div>
            </div>
            
            <div id="test-results" style="display:none;">
                <div class="results-card">
                    <div class="results-header" id="res-score">Результат: 0%</div>
                    <div style="font-size:14px; margin-bottom:15px; text-align:center; color:#9aa5b9;" id="res-comment">Анализ...</div>
                    <div id="test-result-actions" style="margin-bottom:20px;"></div>
                    <div id="wrong-answers-list"></div>
                    <button class="action-btn primary" style="margin-top:15px; width:100%; background:#202531;" onclick="resetTest(false)">Пройти заново</button>
                </div>
            </div>
        </div>

        <!-- ИГРА: ПОДБОР -->
        <div id="match-tab" class="panel">
            <div id="match-intro" style="text-align: center; padding: 20px 0;">
                <h2 style="margin-bottom: 15px; font-size: 22px;">Готовы?</h2>
                <p style="color: #9aa5b9; font-size: 14px; line-height: 1.5; margin-bottom: 25px;">
                    Сопоставьте все термины и определения как можно быстрее.<br>
                    <strong style="color:#ef4444;">Избегайте промахов</strong> — за каждую ошибку добавляется 1 штрафная секунда!
                </p>
                <button class="action-btn primary" style="width: 100%; max-width: 250px; padding: 15px;" onclick="startMatch()">Начать игру</button>
            </div>
            <div id="match-game" style="display:none;">
                <div class="match-timer" id="match-timer">0.0 сек</div>
                <div class="match-board" id="match-board"></div>
            </div>
            <div id="match-results" style="display:none; text-align: center; padding: 20px 0;">
                <div style="font-size: 40px; margin-bottom: 10px;">🏆</div>
                <h2 style="margin-bottom: 10px; color: #10b981;">Идеально!</h2>
                <p style="color: #9aa5b9; margin-bottom: 5px;">Ваше время:</p>
                <div style="font-size: 36px; font-weight: 700; color: #ffffff; margin-bottom: 25px;" id="match-final-time">0.0 сек</div>
                <button class="action-btn primary" style="width: 100%; max-width: 250px;" onclick="initMatch()">Играть снова</button>
            </div>
        </div>

        <!-- ФЕЙНМАН -->
        <div id="feynman-tab" class="panel">
            <div style="font-size: 13px; color: #7c8596; margin-bottom: 15px; text-align: center;">
                💡 Объясните этот регламент вслух простыми словами.
            </div>
            <div class="card-box" style="min-height:120px; cursor:default;">
                <div class="type" style="color:#10b981;">Задание на объяснение</div>
                <div class="card-text" id="feynman-question">Загрузка...</div>
            </div>
            <button class="action-btn primary" id="feynman-reveal-btn" onclick="revealFeynmanAnswer()">Показать эталонный ответ</button>
            <div class="feynman-answer" id="feynman-answer-box"></div>
            
            <div class="nav-layout" id="feynman-nav" style="display:none; margin-top:15px;">
                <button class="action-btn" style="background:#ef4444;" onclick="nextFeynman(false)">Плохо помню</button>
                <button class="action-btn" style="background:#10b981;" onclick="nextFeynman(true)">Отлично объяснил</button>
            </div>
            <div class="score-counter" id="feynman-counter" style="margin-top:10px;">Пройдено: 0</div>
        </div>

        <!-- ТАБЛИЦЫ -->
        <div id="matrix-tab" class="panel">
            <div style="font-size: 13px; color: #7c8596; margin-bottom: 15px; text-align: center;">
                💡 Нажимай на серые блоки, чтобы открыть этапы.
            </div>
            <button class="action-btn" style="margin-bottom: 15px; width:100%; background: #202531;" onclick="renderMatrix()">Скрыть все ответы</button>
            <div id="matrix-container"></div>
        </div>
    </div>

    <!-- Модалка для увеличения схемы -->
    <div class="img-modal" id="img-modal" onclick="closeImgModal()">
        <img id="img-modal-content" src="" />
    </div>

    <!-- ЧАТ-АССИСТЕНТ -->
    <button class="chat-fab" id="chat-fab" onclick="toggleChat()">💬</button>
    <div class="chat-panel" id="chat-panel">
        <div class="chat-header">
            <span>🤖 Помощник по теории</span>
            <span class="chat-close" onclick="toggleChat()">✕</span>
        </div>
        <div class="chat-messages" id="chat-messages">
            <div class="chat-msg bot">Привет! Спроси меня о чём угодно из теории: грейды, лидерство, аналитика, переговоры, декомпозиция и т.д.</div>
        </div>
        <div class="chat-hint">Отвечаю только на основе базы знаний тренажёра</div>
        <div class="chat-input-row">
            <input type="text" id="chat-input" placeholder="Задай вопрос..." onkeydown="if(event.key==='Enter') sendChatMessage();">
            <button onclick="sendChatMessage()">➤</button>
        </div>
    </div>

    <script>
        function cleanText(txt) {
            if (!txt) return "";
            return txt.replace(/\[span_\d+\]\(start_span\)\[span_\d+\]\(end_span\)/g, "")
                      .replace(/\[span_\d+\]/g, "")
                      .replace(/\(start_span\)/g, "")
                      .replace(/\(end_span\)/g, "")
                      .trim();
        }

        const schemeImages = {
            "competencies": "data:image/jpeg;base64,",
            "analytics": "data:image/jpeg;base64,",
            "grades_scheme": "data:image/jpeg;base64,",
            "decomposition": "data:image/jpeg;base64,",
            "grades_table": "data:image/jpeg;base64,",
            "negotiation": "data:image/jpeg;base64,",
            "mbo_di": "data:image/jpeg;base64,",
        };

        const database = [
            { q: "Какова ключевая миссия ОЭЗ «Алабуга»?", a: "«Мы растим промышленность для благополучия людей, создавая лучшую в мире инфраструктуру».", options: ["«Мы растим промышленность для благополучия людей, создавая лучшую в мире инфраструктуру».", "Рост промышленного потенциала РФ и создание лучшей инфраструктуры.", "Привлечение иностранных инвестиций в высокотехнологичные отрасли экономики.", "Обеспечение кадровой, социальной, промышленной и строительной инфраструктуры."], t: "Миссия Алабуги сформулирована дословно: «Мы растим промышленность для благополучия людей, создавая лучшую в мире инфраструктуру». Это фундамент корпоративной культуры." },
            { q: "Что такое корпоративная культура в понимании Алабуги?", a: "Корпоративная культура это нормы и образцы поведения, которые определяют деятельность всех сотрудников компании и отношения между ними.", options: ["Корпоративная культура это нормы и образцы поведения, которые определяют деятельность всех сотрудников компании и отношения между ними.", "Это система грейдов и должностных должностей, привязанная к идеологическим группам.", "Это жесткое соблюдение тайм-менеджмента и дисциплинарных регламентов.", "Это правила, направленные исключительно на развитие лидерских качеств стажеров."], t: "Корпоративная культура — это не просто лозунги, а конкретные нормы и образцы реального поведения, определяющие как работу, так и внутреннее общение сотрудников." },
            { q: "Зачем нужны заводы согласно описанию миссии компании?", a: "Заводы это налоги для государства и это заработная плата для людей.", options: ["Заводы это налоги для государства и это заработная плата для людей.", "Заводы нужны для выполнения планов Vision компании.", "Для развития строительной инфраструктуры региона.", "Для выполнения KPI руководящего состава."], t: "В миссии чётко закреплена социально-экономическая роль заводов: они генерируют налоги для развития государства и обеспечивают достойную зарплату для граждан." },
            { q: "Что предполагает лучшая в мире инфраструктура в контексте современных задач?", a: "Это предполагает и финансовую, и HR-инфраструктуру.", options: ["Это предполагает и финансовую, и HR-инфраструктуру.", "Только автомобильные и железные дороги, электричество и водопровод.", "Создание 10 площадок свободной таможенной зоны.", "Организацию практики стажеров Политиха."], t: "Инфраструктура полного цикла в Алабуге вышла далеко за рамки труб и дорог. Сегодня лучшая инфраструктура обязательно включает в себя мощную финансовую поддержку проектов и отлаженную HR-систему подготовки кадров." },
            { q: "Каков лозунг ценности «Каждому по результату»?", a: "В Советском Союзе был лозунг «Каждому по труду!» У нас в «Алабуге» не так. Мы оцениваем людей по результату.", options: ["В Советском Союзе был лозунг «Каждому по труду!» У нас в «Алабуге» не так. Мы оцениваем людей по результату.", "Каждому по труду и усердию на рабочем месте.", "Сотрудник получает поощрение за выполнение процесса.", "Снятие проверки осуществляется единоразово."], t: "Компания противопоставляет себя советскому подходу «по труду (процессу)». Нам важен только конечный измеримый итог. Усердие без результата ценности не имеет." },
            { q: "За за что сотрудников будут порицать в рамках ценности результатов?", a: "его будут порицать за бездействие, за лень!", options: ["его будут порицать за бездействие, за лень!", "За совершение технических ошибок на производстве.", "За выход из зоны своего комфорта.", "За отсутствие прямого согласования задач."], t: "Ошибки на пути к достижению цели допустимы, но бездействие, лень и равнодушие в Алабуге караются жестким корпоративным порицанием." },
            { q: "Какова позиция лидера при обнаружении неэффективности или проблемы?", a: "Он не делегирует наверх проблемы он предлагает решения. Если он видит неэффективность, то старается устранить ее, если видит проблему, то решает её.", options: ["Он не делегирует наверх проблемы он предлагает решения. Если он видит неэффективность, то старается устранить ее, если видит проблему, то решает её.", "Он передает проблему на уровень вышестоящего ЗГД.", "Он фиксирует её в системе 1С:KPI как ДИ.", "Он ждет официального поручения от руководства."], t: "Принцип владельца процесса: лидер никогда не спихивает проблему руководителю. Он приходит наверх только с готовыми вариантами решений и берёт ответственность за их внедрение." },
            { q: "Какой объем импорта в Россию зафиксирован в стратегии развития?", a: "более 22 трлн. рублей", options: ["более 22 трлн. рублей", "более 10 трлн. рублей", "около 50 трлн. рублей", "15 трлн. рублей"], t: "Стратегия Алабуги опирается на цифру импорта РФ в размере более 22 трлн рублей. Цель компании — заместить этот импорт внутренним высокотехнологичным производством." },
            { q: "Сколько собственных производств предполагает создать Vision компании?", a: "не менее 50 собственных производств", options: ["не менее 50 собственных производств", "43 действующих производства", "10 площадок", "22 ступени"], t: "Долгосрочный Vision Алабуги ставит глобальную цель — развернуть и запустить не менее 50 мощных собственных производств на территории макроплощадок." },
            { q: "Сколько площадок по всей стране предполагает Vision компании?", a: "10 площадок", options: ["10 площадок", "50 площадок", "43 площадки", "22 площадки"], t: "Масштабирование инфраструктурного партнера полного цикла предусматривает создание сети из 10 крупных индустриальных площадок по всей Российской Федерации." },
            { q: "Что произойдет, если довольствоваться тем, чего уже добился (Стремление к большему)?", a: "начнется деградация. Не будет необходимости в приобретении новых знаний и навыков", options: ["начнется деградация. Не будет необходимости в приобретении новых знаний и навыков", "Сотрудник зафиксируется на своем текущем грейде.", "Произойдет автоматический переход в группу Эксплуатации.", "Увеличится урон без декомпозиции задач."], t: "Остановка на достигнутом — это ловушка. Как только пропадает стремление к большему, неизбежно начинается деградация, так как мозг перестает запрашивать новые знания." },
            { q: "Дайте определение компетенции «Критичность мышления»:", a: "Способность мышления, при котором человек ставит под сомнение поступающую информацию, требует доказательств, принимает только факты", options: ["Способность мышления, при котором человек ставит под сомнение поступающую информацию, требует доказательств, принимает только факты", "Видеть всю картину в целом (что на что влияет, взаимосвязи)", "Разбивать сложные задачи на простые; планировать во времени", "Точно и своевременно доносить неприятную информацию"], t: "Критичность мышления — базовая компетенция аналитика. Нельзя верить чужим словам на слово; лидер требует верифицированных данных, первоисточников и неопровержимых фактов.", img: "competencies" },
            { q: "Какой уровень аналитики требуется, если Алабуга проверяет Бизнес-План с ТУ от 5 до 10 Мвт?", a: "уровень аналитики 6 (Федеральный)", options: ["уровень аналитики 6 (Федеральный)", "без проверки", "уровень аналитики 7 (Мировые практики)", "уровень аналитики 8 (Лучшие мировые практики)"], t: "Согласно регламенту, масштабы мощностей ТУ от 5 до 10 Мвт автоматически требуют жесткого разбора ситуации на Уровне 6 (Федеральный масштаб аналитики).", img: "analytics" },
            { q: "Какой уровень аналитики требуется при проверке ТУ от 10 до 15 Мвт?", a: "уровень аналитики 7 (Мировые практики)", options: ["уровень аналитики 7 (Мировые практики)", "уровень аналитики 6 (Федеральный)", "уровень аналитики 8 (Лучшие мировые практики)", "без проверки"], t: "Потребление мощностей свыше 10 Мвт (в границах 10-15 Мвт) — это уровень крупнейших предприятий. Аналитика обязана проводиться по Уровню 7 (Мировые практики).", img: "analytics" },
            { q: "Как меняется уровень проведения аналитики при работе со странами ЕАЭС?", a: "увеличивается в 3 раза.", options: ["увеличивается в 3 раза.", "Увеличивается в 2 раза.", "Остается неизменным.", "Снижается до уровня Сельмаг."], t: "Выход на международные рынки ЕАЭС несет повышенные риски, поэтому глубина, детализация и требования к аналитическим исследованиям возрастают ровно в 3 раза.", img: "analytics" },
            { q: "Если стоимость контакта с Клиентом составляет 400 т.р., какой минимальный уровень аналитики необходим?", a: "минимум на уровне 7 (Мировые практики)", options: ["минимум на уровне 7 (Мировые практики)", "уровень 6 (Федеральный)", "уровень 8 (Лучшие мировые практики)", "уровень 5 (Региональный)"], t: "Дорогие контакты с клиентами (от 400 тыс. рублей) запрещено анализировать поверхностно. Стандарт компании — проработка аналитики не ниже Уровня 7 (Мировые практики).", img: "analytics" },
            { q: "Каковы минимумы прямых подчиненных/модулей для должностей ЗГД, РГП и РП в схеме грейдов?", a: "ЗГД — минимум 8 прямых подчинённых/модулей; РГП — минимум 6 прямых подчинённых/модулей; РП — минимум 4 прямых подчинённых/модуля.", options: ["ЗГД — минимум 8 прямых подчинённых/модулей; РГП — минимум 6 прямых подчинённых/модулей; РП — минимум 4 прямых подчинённых/модуля.", "ЗГД — 10, РГП — 8, РП — 6.", "Для всех должностей минимум 4 подчиненных.", "ЗГД — 6, РГП — 4, РП — 2."], t: "Четвертичная система структуры грейдов жестко привязывает позицию к числу модулей в подчинении: для РП — от 4, для РГП — от 6, для ЗГД — не менее 8 прямых модулей.", img: "grades_scheme" },
            { q: "Что такое маржа в соответствии с материалом?", a: "Маржа - это разница между себестоимостью товара и ценой, по которой продают товар.", options: ["Маржа - это разница между себестоимостью товара и ценой, по которой продают товар.", "Резерв в размере 5% от стоимости контракта.", "Чистая приведённая стоимость финансового показателя.", "Разница между импортом и внутренним производством."], t: "Маржа в экономике Алабуги — это классическая разница между полной финальной себестоимостью продукта и ценой его конечной реализации контрагенту." },
            { q: "Что такое Хвостик в закупках ОЭЗ Алабуга?", a: "Хвостик - 5%* наша оценка себестоимости + маржа контрагента (сумма в резерве).", options: ["Хвостик - 5%* наша оценка себестоимости + маржа контрагента (сумма в резерве).", "Штрафной балл за задержку сдачи документов в 1С.", "Показатель инфляции при долгосрочном планировании.", "Разница между себестоимостью товара и ценой его продажи."], t: "«Хвостик» в закупках — это защитный финансовый буфер, который рассчитывается как: 5% от нашей внутренней оценки себестоимости плюс заложенная маржа контрагента. Эта сумма удерживается в резерве." },
            { q: "Какова формула расчета показателя NPV?", a: "NPV = сумма(Pk / (1 + i)^n) - IC", options: ["NPV = сумма(Pk / (1 + i)^n) - IC", "NPV = сумма(Pk * i^n) + IC", "маржа * 5% + IC", "себестоимость + маржа контрагента"], t: "Формула NPV дисконтирует будущие денежные потоки: сумма всех поступлений Pk, деленная на (1 + ставка дисконтирования i) в степени периода n, за вычетом первоначальных инвестиций IC." },
            { q: "Что такое декомпозиция на 8 уровне в таблице декомпозиции?", a: "Результат 99%, Урон 1%, Необходимый уровень: Forward, Частота: по результату.", options: ["Результат 99%, Урон 1%, Необходимый уровень: Forward, Частота: по результату.", "Результат 87%, Урон 8%, Три ключевых вводных, Ежемесячно.", "Результат 70%, Урон 15%, Девять важных вводных, Еженедельно.", "Результат 50%, Урон 40%, пошагово по SMART'у, Ежедневно."], t: "Высочайший уровень управления (Уровень 8). Сотрудник работает полностью автономно (Forward), выдает результат 99% при минимальном уровне урона 1%.", img: "decomposition" },
            { q: "Что такое декомпозиция на 7 уровне в таблице?", a: "Результат 87%, Урон 8%, Необходимый уровень: Три ключевых вводных, Частота: Ежемесячно.", options: ["Результат 87%, Урон 8%, Необходимый уровень: Три ключевых вводных, Частота: Ежемесячно.", "Результат 70%, Урон 15%, Девять важных вводных, Еженедельно.", "Результат 50%, Урон 40%, пошагово по SMART'у, Ежедневно.", "Результат 99%, Урон 1%, по результату."], t: "Уровень 7 декомпозиции целей означает: руководитель дает сотруднику всего 3 ключевых вводных, проверка идет раз в месяц, ожидаемый результат — 87%, допустимый урон — 8%.", img: "decomposition" },
            { q: "Что такое декомпозиция на 6 уровне в таблице?", a: "Результат 70%, Урон 15%, Необходимый уровень: Девять важных вводных пошагово по SMART'у, Частота: Еженедельно.", options: ["Результат 70%, Урон 15%, Необходимый уровень: Девять важных вводных пошагово по SMART'у, Частота: Еженедельно.", "Результат 50%, Урон 40%, пошагово по SMART'у, Ежедневно.", "Результат 35%, Урон 50%, пошагово по SMART'у, Ежедневно.", "Результат 87%, Урон 8%, Ежемесячно."], t: "Уровень 6 требует более плотного ведения задач: сотруднику выдается 9 важных вводных по SMART, контроль осуществляется еженедельно, плановый результат — 70%, урон — 15%.", img: "decomposition" },
            { q: "Что такое декомпозиция на 5 уровне в таблице?", a: "Результат 50%, Урон 40%, Необходимый уровень: пошагово по SMART'у, Частота: Ежедневно.", options: ["Результат 50%, Урон 40%, Необходимый уровень: пошагово по SMART'у, Частота: Ежедневно.", "Результат 35%, Урон 50%, пошагово по SMART'у, Ежедневно.", "Результат 15%, Урон 65%, пошагово по SMART'у, Ежедневно.", "Результат 70%, Урон 15%, Еженедельно."], t: "Уровень 5 — это микроуправление начального уровня стажеров: пошаговое ведение по SMART'у, контроль каждый день, результат всего 50%, а урон составляет колоссальные 40%.", img: "decomposition" },
            { q: "Что такое декомпозиция на 1 уровне в таблице?", a: "Результат 5%, Урон 90%, Необходимый уровень: пошагово по SMART'у, Частота: Ежедневно.", options: ["Результат 5%, Урон 90%, Необходимый уровень: пошагово по SMART'у, Частота: Ежедневно.", "Результат 10%, Урон 80%, пошагово по SMART'у, Ежедневно.", "Результат 15%, Урон 65%, пошагово по SMART'у, Ежедневно.", "Результат 35%, Урон 50%, пошагово по SMART'у, Ежедневно."], t: "Уровень 1 — критически опасный уровень несамостоятельности. Сотрудник выдает лишь 5% результата при гигантском уроне для компании в 90%.", img: "decomposition" },
            { q: "Что такое цели вида МВО в карте целей?", a: "Задачи МИРОВОГО уровня, выполняемые сотрудником САМОСТОЯТЕЛЬНО на основании вводных данных от руководителя. Вносятся самостоятельно в 1С:KPI по системе SMART.", options: ["Задачи МИРОВОГО уровня, выполняемые сотрудником САМОСТОЯТЕЛЬНО на основании вводных данных от руководителя. Вносятся самостоятельно в 1С:KPI по системе SMART.", "Задачи, устанавливаемые сотрудниками АГД заведомо закрытыми в систему, формулировки которых не подлежат изменению.", "Регулярные базовые задачи, жестко ограниченные рамками должностной инструкции.", "Поручения, закрытие которых в системе осуществляется руководителем многократно."], t: "MBO (Management by Objectives) — масштабные стратегические задачи мирового уровня сложности. Сотрудник декомпозирует и вносит их в 1С:KPI сам, ведя проект автономно.", img: "mbo_di" },
            { q: "Что такое цели вида ДИ в карте целей?", a: "Устанавливаются сотрудниками АГД заведомо закрытыми в систему 1С:KPI. Формулировки и вес не подлежат изменению. Включают базовые регулярные и нерегулярные задачи, но не ограничиваются должностными инструкциями.", options: ["Устанавливаются сотрудниками АГД заведомо закрытыми в систему 1С:KPI. Формулировки и вес не подлежат изменению. Включают базовые регулярные и нерегулярные задачи, но не ограничиваются должностными инструкциями.", "Задачи мирового уровня, выполняемые самостоятельно на основании вводных данных.", "Задачи строительного сектора, вносимые в карту целей раз в год.", "Поручения, которые можно повторно прожать после исправления ошибок."], t: "ДИ (Должностная Инструкция) — это жестко спускаемые сверху задачи. Их формулировки и вес заблокированы для изменений. Они охватывают все операционные задачи и стандарты качества работы.", img: "mbo_di" },
            { q: "Какое жесткое правило действует для руководителя при закрытии целей ДИ?", a: "Снятие проверки выполнения данной группы задач осуществляется руководителем единоразово, без возможности повторного прожатия.", options: ["Снятие проверки выполнения данной группы задач осуществляется руководителем единоразово, без возможности повторного прожатия.", "Руководитель обязан проверять ДИ ежедневно.", "Снятие проверки возможно только в присутствии сотрудника АГД.", "Проверка закрывается автоматически в конце каждого calendarного месяца."], t: "Правило одного шанса: руководитель проверяет и оценивает выполнение блока ДИ только один раз за период. Исправить плохую оценку или «перепрожать» задачу заново регламент запрещает.", img: "mbo_di" },
            { q: "Сколько принципов лидерства действует в компании?", a: "7 принципов лидерства", options: ["7 принципов лидерства", "4 принципа", "21 принцип", "22 принципа"], t: "В Алабуге официально утверждено и применяется ровно 7 ключевых корпоративных принципов лидерства, которые обязан соблюдать каждый руководитель проекта." },
            { q: "Какую позицию занимает Лидер по отношению к процессу?", a: "Лидер владелец процесса, а не наемный рабочий. Он не делегирует наверх проблемы он предлагает решения.", options: ["Лидер владелец процесса, а не наемный рабочий. Он не делегирует наверх проблемы он предлагает решения.", "Лидер полностью сфокусирован на процессе, а не на результате.", "Лидер делегирует все возникающие проблемы вышестоящему руководству.", "Лидер выполняет только задачи в рамках должностной инструкции."], t: "Разница между лидером и обычным исполнителем: лидер относится к компании как к собственному бизнесу. Любая проблема на его участке — это вызов, который он решает сам, а не спихивает наверх." },
            { q: "На какие 3 направления разделяется система делегирования в ОЭЗ Алабуга?", a: "Идеология, Эксплуатация, Строительство.", options: ["Идеология, Эксплуатация, Строительство.", "Аналитика, Переговоры, Результат.", "Управление, Контроль, Исполнение.", "Стажеры, Специалисты, Руководители."], t: "Вся оргструктура управления и делегирования задач Алабуги жестко делится на три обособленных вертикальных трека: Идеология (стратегия/HR), Эксплуатация (поддержание) и Строительство (развитие)." },
            { q: "Какую роль играют Идеологи в системе делегирования?", a: "Идеологи принимают ключевые решения, которые закладывают в проект экономический эффект от всего проекта.", options: ["Идеологи принимают ключевые решения, которые закладывают в проект экономический эффект от всего проекта.", "Разрабатывают технические решения, влияющие на эксплуатацию.", "Реализуют проект в соответствии со строительной политикой.", "Контролируют выполнение ежедневных пошаговых планов по SMART."], t: "Идеологи — это высший мозг проекта. Они не занимаются стройкой или трубами; их задача — долгосрочное планирование, расчет макроэкономики и закладывание глобального бизнес-эффекта." },
            { q: "Сколько ступеней содержит грейдовая система Алабуги?", a: "Всего в грейдовой системе 22 ступени.", options: ["Всего в грейдовой системе 22 ступени.", "Сетка состоит из 21 ступени.", "Сетка включает 10 ступеней.", "Система состоит из 4 уровней градации должностей."], t: "Сетка профессионального и карьерного роста в ОЭЗ разбита ровно на 22 грейда (от нулевого стартового до высшего руководящего).", img: "grades_table" },
            { q: "С какого грейда начинают все стажеры независимо от идеологической группы?", a: "Независимо от идеологической группы все стажёры начинают с нулевого грейда.", options: ["Независимо от идеологической группы все стажёры начинают с нулевого грейда.", "Все стажеры начинают с 1 грейда.", "Стажеры начинают с грейда, назначенного Навигатором.", "Стажеры начинают со 2 грейда (младший специалист)."], t: "В Алабуге действует жесткая меритократия. Никакой прошлый опыт не позволяет перескочить ступени на старте — абсолютно все асессоры и стажеры начинают карьеру строго с 0 грейда.", img: "grades_table" },
            { q: "Должность Генерального директора (ГД) относится к какому грейду?", a: "21 ГРЕЙД", options: ["21 ГРЕЙД", "22 ГРЕЙД", "20 ГРЕЙД", "19 ГРЕЙД"], t: "Генеральный директор ОЭЗ занимает 21 грейд в иерархической структуре компании, что на одну ступень ниже абсолютного максимума тарифной сетки.", img: "grades_table" },
            { q: "Должности ЗГД по HR, Руководитель АГД и Главный конструктор относятся к какому грейду?", a: "20 ГРЕЙД", options: ["20 ГРЕЙД", "21 ГРЕЙД", "19 ГРЕЙД", "18 ГРЕЙД"], t: "Ключевые топ-менеджеры компании (руководство HR-вертикали, лидеры ключевых департаментов и главные инженеры проектов) находятся на высокой планке 20 грейда.", img: "grades_table" },
            { q: "Как часто происходит пересмотр грейда для сотрудников компании?", a: "Пересмотр грейда происходит не реже 1 раза в год.", options: ["Пересмотр грейда происходит не реже 1 раза в год.", "Раз в полгода по результатам закрытия карт целей.", "Каждые 3 месяца на корпоративных ассессментах.", "Раз в два года по решению Генерального директора."], t: "Регламент гарантирует регулярную оценку: профессиональный уровень и соответствующий ему грейд сотрудника пересматриваются по результатам KPI комиссий не реже одного раза в год.", img: "grades_table" },
            { q: "Что такое модуль в четвертичной системе управления HR?", a: "Единица штатного расписания, сформированная в соответствии с четвертичной системой управлением HR", options: ["Единица штатного расписания, сформированная в соответствии с четвертичной системой управлением HR", "Отдельная вкладка в системе 1С:KPI для стажеров.", "Направление Идеологии и Эксплуатации.", "Уровень проведения аналитики мирового масштаба."], t: "Модуль — это базовый кирпичик структуры Алабуги. Это не конкретный человек, а автономная расчетная единица штатного расписания, созданная по правилам четвертичной системы HR.", img: "grades_scheme" },
            { q: "Какой уровень аналитики требуется, если Алабуга делает Бизнес План?", a: "требуется уровень минимум 7 (Мировые практики)", options: ["требуется уровень минимум 7 (Мировые практики)", "уровень аналитики 6 (Федеральный)", "уровень аналитики 8 (Лучшие мировые практики)", "уровень 5 (Региональный)"], t: "Создание любого нового Бизнес-плана развития инфраструктуры — задача высочайшего приоритета. Запрещено опускаться ниже стандартов Уровня 7 (Мировые практики).", img: "analytics" },
            { q: "Если Алабуга проводит переговоры со стратегически важной целью, какое условие обязательно?", a: "в любом случае они проводятся с информированием Генерального директора.", options: ["в любом случае они проводятся с информированием Генерального директора.", "Они проводятся исключительно на уровне ГД-1.", "Необходим уровень амбиций не ниже 8.", "Обязательно использование ковровой дорожки на первом шаге."], t: "Стратегические переговоры — зона особого контроля. Кто бы их ни вел из проектных менеджеров, регламент обязывает в любом случае держать Генерального директора в курсе хода диалога.", img: "negotiation" }
        ];

        const tablesData = [
            { section: "Алгоритм аналитики (9 этапов)", data: [
                { s: "Этап 1", v: "Потребности клиента и стейкхолдеров (кому, объемы, качество, сроки)" },
                { s: "Этап 2", v: "Оценка рисков" },
                { s: "Этап 3", v: "Сбор первичных данных" },
                { s: "Этап 4", v: "Проверка данных (основной достоверный источник знаний)" },
                { s: "Этап 5", v: "Мозговой штурм (генерация идей, рассмотрение максимально большего)" },
                { s: "Этап 6", v: "Фильтрация идей (отказаться от бесперспективных)" },
                { s: "Этап 7", v: "Второй круг проверки коммерческих предложений при закупках" },
                { s: "Этап 8", v: "Тестирование презентации и выводов на стейкхолдерах" },
                { s: "Этап 9", v: "Показать результаты клиенту стейкхолдеру" }
            ]},
            { section: "Алгоритм переговоров (8 этапов)", data: [
                { s: "Шаг 1", v: "Начать переговоры" },
                { s: "Шаг 2", v: "Выслушать клиента" },
                { s: "Шаг 3", v: "Привести аргументы №1" },
                { s: "Шаг 4", v: "Дзен" },
                { s: "Шаг 5", v: "Не уходить" },
                { s: "Шаг 6", v: "Вернуться" },
                { s: "Шаг 7", v: "Привести аргументы №2" },
                { s: "Шаг 8", v: "Получить результат" }
            ]},
            { section: "Амбиции по аналитике (ЗКА)", data: [
                { s: "Уровень 1", v: "БАБУШКА" }, { s: "Уровень 2", v: "ДВОР" }, { s: "Уровень 3", v: "СЕЛЬМАГ" },
                { s: "Уровень 4", v: "МУНИЦИПАЛЬНЫЙ УРОВЕНЬ" }, { s: "Уровень 5", v: "РЕГИОНАЛЬНЫЙ УРОВЕНЬ" },
                { s: "Уровень 6", v: "ФЕДЕРАЛЬНЫЙ УРОВЕНЬ" }, { s: "Уровень 7", v: "МИРОВЫЕ ПРАКТИКИ" },
                { s: "Уровень 8", v: "ЛУЧШИЕ МИРОВЫЕ ПРАКТИКИ" }
            ]},
            { section: "Амбиции по общению (ЗКО)", data: [
                { s: "Уровень 1", v: "БАБУШКА" }, { s: "Уровень 2", v: "ДВОР" }, { s: "Уровень 3", v: "ОТДЕЛ" },
                { s: "Уровень 4", v: "ЗАМ. ДИРЕКТОРА ТИПОВОГО РЕЗИДЕНТА / РЕГИОНАЛЬНЫЙ НАЧАЛЬНИК ОТДЕЛА" },
                { s: "Уровень 5", v: "ДИРЕКТОР ТИПОВОГО РЕЗИДЕНТА / ЗГД / РЕГИОНАЛЬНЫЙ НАЧАЛЬНИК УПРАВЛЕНИЯ" },
                { s: "Уровень 6", v: "ДИРЕКТОР КЛЮЧЕВОГО ЗАВОДА РЕЗИДЕНТА (БОЛЕЕ 3 МЛРД. РУБ. ВЫРУЧКИ) / МЭР / ГД / ЗАММИНИСТРА РТ" },
                { s: "Уровень 7", v: "РУКОВОДИТЕЛЬ ФЕДЕРАЛЬНОГО ХОЛДИНГА / ДИРЕКТОР ДЕПАРТАМЕНТА РФ / МИНИСТР РТ" },
                { s: "Уровень 8", v: "МИНИСТР И ЗАММИНИСТРА РФ" }
            ]}
        ];

        let cardIdx = 0, isAns = false;
        let quizQueue = [], currentQueueIdx = 0, testAnswered = false, initialTotal = 0, correctFirstTimeCount = 0, wrongAnswers = [], historicalWrongs = [];
        let feynmanList = [], currentFeynmanIdx = 0, feynmanCount = 0;

        function switchTab(tabId, btn) {
            document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            btn.classList.add('active');
            
            if(tabId === 'test-tab' && quizQueue.length === 0) resetTest(false);
            if(tabId === 'feynman-tab') initFeynman();
            if(tabId === 'matrix-tab') renderMatrix();
            if(tabId === 'match-tab') initMatch();
        }

        /* ПОМОДОР ТАЙМЕР */
        let pomoMinutes = 50, pomoSeconds = 0, pomoInterval = null, pomoIsWork = true, pomoIsRunning = false;
        function togglePomodoro() {
            const btn = document.getElementById('pomo-toggle');
            if (pomoIsRunning) {
                clearInterval(pomoInterval); btn.innerText = "Старт"; pomoIsRunning = false;
            } else {
                pomoIsRunning = true; btn.innerText = "Пауза";
                pomoInterval = setInterval(() => {
                    if (pomoSeconds === 0) {
                        if (pomoMinutes === 0) {
                            pomoIsWork = !pomoIsWork;
                            if (pomoIsWork) {
                                pomoMinutes = 50; document.getElementById('pomo-label').innerText = "Помодоро: Время работать!";
                                document.getElementById('pomo-dot').className = "pomo-status work";
                            } else {
                                pomoMinutes = 10; document.getElementById('pomo-label').innerText = "Помодоро: Время отдыхать";
                                document.getElementById('pomo-dot').className = "pomo-status break";
                            }
                        } else { pomoMinutes--; pomoSeconds = 59; }
                    } else { pomoSeconds--; }
                    document.getElementById('pomo-display').innerText = (pomoMinutes < 10 ? "0" + pomoMinutes : pomoMinutes) + ":" + (pomoSeconds < 10 ? "0" + pomoSeconds : pomoSeconds);
                }, 1000);
            }
        }

        /* КАРТОЧКИ */
        function updateCard() {
            const item = database[cardIdx];
            document.getElementById('card-main').innerText = cleanText(isAns ? item.a : item.q);
            document.getElementById('card-type').innerText = isAns ? "Ответ" : "Вопрос";
            document.getElementById('card-type').style.color = isAns ? "#10b981" : "#0066FF";
            document.getElementById('card-index').innerText = (cardIdx + 1) + " / " + database.length;
        }
        function flipCard() { isAns = !isAns; updateCard(); }
        function nextCard() { cardIdx = (cardIdx + 1) % database.length; isAns = false; updateCard(); }
        function prevCard() { cardIdx = (cardIdx - 1 + database.length) % database.length; isAns = false; updateCard(); }

        /* ТЕСТИРОВАНИЕ С ИНТЕРАКТИВНОЙ ТЕОРИЕЙ */
        function resetTest(onlyErrors = false) {
            let baseList = database;
            if (onlyErrors) {
                baseList = database.filter(item => historicalWrongs.includes(item.q));
            }
            quizQueue = baseList.map(item => ({ q: item.q, a: item.a, options: item.options, t: item.t, img: item.img, state: 'initial' })).sort(() => Math.random() - 0.5);
            currentQueueIdx = 0; correctFirstTimeCount = 0; initialTotal = quizQueue.length; wrongAnswers = [];
            
            document.getElementById('test-gameplay').style.display = 'block';
            document.getElementById('test-results').style.display = 'none';
            document.getElementById('test-theory-box').style.display = 'none';
            document.getElementById('dont-know-btn').style.display = 'block';
            loadTestQuestion();
        }

        function loadTestQuestion() {
            testAnswered = false;
            document.getElementById('test-theory-box').style.display = 'none';
            document.getElementById('dont-know-btn').style.display = 'block';
            
            let activeItems = quizQueue.filter(item => item.state !== 'done');
            if (activeItems.length === 0) { showResults(); return; }
            if (currentQueueIdx >= activeItems.length) currentQueueIdx = 0;

            const currentItem = activeItems[currentQueueIdx];
            document.getElementById('test-question').innerText = cleanText(currentItem.q);
            document.getElementById('test-index').innerText = "Осталось доучить: " + activeItems.length + " из " + initialTotal;
            
            const container = document.getElementById('test-options');
            container.innerHTML = '';
            
            const opts = [...currentItem.options].sort(() => Math.random() - 0.5);
            opts.forEach(opt => {
                const b = document.createElement('button');
                b.className = 'option-btn';
                b.innerText = cleanText(opt);
                b.onclick = () => checkAnswer(b, cleanText(opt), currentItem);
                container.appendChild(b);
            });
        }

        function checkAnswer(btn, chosen, currentItem) {
            if(testAnswered) return;
            testAnswered = true;
            document.getElementById('dont-know-btn').style.display = 'none'; // Убираем кнопку "Не знаю", раз ответ дан
            
            const correctText = cleanText(currentItem.a);
            if(chosen === correctText) {
                btn.classList.add('correct');
                if (currentItem.state === 'initial') { currentItem.state = 'done'; correctFirstTimeCount++; }
                else if (currentItem.state === 'wait3') { currentItem.state = 'wait7'; }
                else if (currentItem.state === 'wait7') { currentItem.state = 'done'; }
            } else {
                btn.classList.add('wrong');
                handleWrongLogic(currentItem, correctText);
            }
        }

        // Показ теории + схемы (если есть) для текущего вопроса
        function showTheoryFor(item) {
            document.getElementById('test-theory-text').innerText = item.t;
            const imgEl = document.getElementById('test-theory-img');
            if (item.img && schemeImages[item.img]) {
                imgEl.src = schemeImages[item.img];
                imgEl.style.display = 'block';
                imgEl.onclick = () => openImgModal(schemeImages[item.img]);
            } else {
                imgEl.style.display = 'none';
                imgEl.src = '';
            }
            document.getElementById('test-theory-box').style.display = 'block';
        }

        function openImgModal(src) {
            document.getElementById('img-modal-content').src = src;
            document.getElementById('img-modal').classList.add('open');
        }
        function closeImgModal() {
            document.getElementById('img-modal').classList.remove('open');
        }

        // Фишка: Логика кнопки «Не знаю ответа»
        function triggerDontKnowTheory() {
            if (testAnswered) return;
            testAnswered = true;
            
            let activeItems = quizQueue.filter(item => item.state !== 'done');
            const currentItem = activeItems[currentQueueIdx];
            const correctText = cleanText(currentItem.a);
            
            // Подсвечиваем верный вариант, чтобы визуально запомнился
            document.querySelectorAll('.option-btn').forEach(b => {
                if(b.innerText === correctText) b.classList.add('correct');
                b.style.opacity = "0.5";
            });
            
            // Разворачиваем теоретический блок (текст + схема, если есть по материалу)
            showTheoryFor(currentItem);
            document.getElementById('dont-know-btn').style.display = 'none';

            handleWrongLogic(currentItem, correctText);
        }

        function handleWrongLogic(currentItem, correctText) {
            if (!wrongAnswers.some(e => e.q === currentItem.q)) wrongAnswers.push({ q: currentItem.q, a: currentItem.a });
            if (!historicalWrongs.includes(currentItem.q)) historicalWrongs.push(currentItem.q);
            
            currentItem.state = 'wait3'; 
            document.querySelectorAll('.option-btn').forEach(b => { if(b.innerText === correctText) b.classList.add('correct'); });
            
            let currentGlobalIdx = quizQueue.indexOf(currentItem);
            quizQueue.splice(currentGlobalIdx, 1);
            let insertIdx = currentGlobalIdx + 3;
            if (insertIdx > quizQueue.length) insertIdx = quizQueue.length;
            quizQueue.splice(insertIdx, 0, currentItem);
            currentQueueIdx--;
            
            // Сразу показываем текст теории и схему, даже если была просто обычная ошибка
            showTheoryFor(currentItem);
        }

        function nextTestQuestion() {
            if(!testAnswered) return alert("Выберите ответ или нажмите «Не знаю ответа»!");
            currentQueueIdx++;
            loadTestQuestion();
        }

        function showResults() {
            document.getElementById('test-gameplay').style.display = 'none';
            document.getElementById('test-results').style.display = 'block';
            const pct = Math.round((correctFirstTimeCount / initialTotal) * 100);
            document.getElementById('res-score').innerText = "Без ошибок с 1 раза: " + correctFirstTimeCount + " из " + initialTotal + " (" + pct + "%)";
            
            const actionCont = document.getElementById('test-result-actions'); actionCont.innerHTML = '';
            if(wrongAnswers.length > 0) {
                const errBtn = document.createElement('button'); errBtn.className = "action-btn primary"; errBtn.style.width = "100%"; errBtn.style.background = "#ef4444";
                errBtn.innerText = "⚡ Прогнать только ошибки (" + wrongAnswers.length + ")";
                errBtn.onclick = () => resetTest(true); actionCont.appendChild(errBtn);
            }
            const listCont = document.getElementById('wrong-answers-list'); listCont.innerHTML = '';
            wrongAnswers.forEach(item => {
                const itemDiv = document.createElement('div'); itemDiv.className = 'wrong-item';
                const qDiv = document.createElement('div'); qDiv.className = 'wrong-q'; qDiv.innerText = item.q;
                const aDiv = document.createElement('div'); aDiv.innerHTML = 'Правильный текст: <span class="wrong-a">' + item.a + '</span>';
                itemDiv.appendChild(qDiv); itemDiv.appendChild(aDiv); listCont.appendChild(itemDiv);
            });
        }

        /* ИГРА ПОДБОР (MATCH) */
        let matchInterval = null, matchTime = 0, matchSelected = null, matchPairsLeft = 0, isMatchAnimating = false;
        function initMatch() { document.getElementById('match-intro').style.display = 'block'; document.getElementById('match-game').style.display = 'none'; document.getElementById('match-results').style.display = 'none'; if (matchInterval) clearInterval(matchInterval); }
        function startMatch() {
            document.getElementById('match-intro').style.display = 'none'; document.getElementById('match-game').style.display = 'block';
            matchTime = 0; document.getElementById('match-timer').innerText = "0.0 сек";
            let shuffledDb = [...database].sort(() => Math.random() - 0.5).slice(0, 6);
            matchPairsLeft = shuffledDb.length;
            let cardsData = [];
            shuffledDb.forEach((item, index) => {
                cardsData.push({ id: index, text: cleanText(item.q) }); cardsData.push({ id: index, text: cleanText(item.a) });
            });
            cardsData.sort(() => Math.random() - 0.5);
            const board = document.getElementById('match-board'); board.innerHTML = '';
            cardsData.forEach(card => {
                let div = document.createElement('div'); div.className = 'match-card'; div.innerText = card.text; div.dataset.id = card.id;
                div.onclick = () => onMatchCardClick(div); board.appendChild(div);
            });
            if (matchInterval) clearInterval(matchInterval);
            matchInterval = setInterval(() => { matchTime += 0.1; document.getElementById('match-timer').innerText = matchTime.toFixed(1) + " сек"; }, 100);
        }
        function onMatchCardClick(cardEl) {
            if (isMatchAnimating || cardEl.classList.contains('hidden') || cardEl === matchSelected) return;
            if (!matchSelected) { matchSelected = cardEl; cardEl.classList.add('selected'); }
            else {
                if (matchSelected.dataset.id === cardEl.dataset.id) {
                    cardEl.classList.add('selected'); isMatchAnimating = true;
                    setTimeout(() => { cardEl.classList.add('hidden'); matchSelected.classList.add('hidden'); matchSelected = null; isMatchAnimating = false; matchPairsLeft--; if (matchPairsLeft === 0) { clearInterval(matchInterval); document.getElementById('match-game').style.display = 'none'; document.getElementById('match-results').style.display = 'block'; document.getElementById('match-final-time').innerText = matchTime.toFixed(1) + " сек"; } }, 300);
                } else {
                    cardEl.classList.add('wrong'); matchSelected.classList.add('wrong'); matchTime += 1.0; isMatchAnimating = true;
                    setTimeout(() => { cardEl.classList.remove('wrong'); matchSelected.classList.remove('wrong', 'selected'); matchSelected = null; isMatchAnimating = false; }, 500);
                }
            }
        }

        /* МЕТОД ФЕЙНМАНА */
        function initFeynman() { feynmanList = [...database].sort(() => Math.random() - 0.5); currentFeynmanIdx = 0; showFeynmanQuestion(); }
        function showFeynmanQuestion() {
            if (currentFeynmanIdx >= feynmanList.length) { alert("Круг пройден!"); initFeynman(); return; }
            document.getElementById('feynman-question').innerText = cleanText(feynmanList[currentFeynmanIdx].q);
            document.getElementById('feynman-answer-box').style.display = 'none'; document.getElementById('feynman-answer-box').innerText = cleanText(feynmanList[currentFeynmanIdx].a);
            document.getElementById('feynman-reveal-btn').style.display = 'block'; document.getElementById('feynman-nav').style.display = 'none';
            document.getElementById('feynman-counter').innerText = "Пройдено: " + feynmanCount;
        }
        function revealFeynmanAnswer() { document.getElementById('feynman-reveal-btn').style.display = 'none'; document.getElementById('feynman-answer-box').style.display = 'block'; document.getElementById('feynman-nav').style.display = 'flex'; }
        function nextFeynman(isSuccess) { if (isSuccess) { feynmanCount++; currentFeynmanIdx++; } else { let item = feynmanList[currentFeynmanIdx]; feynmanList.splice(currentFeynmanIdx, 1); feynmanList.splice(currentFeynmanIdx + 2, 0, item); } showFeynmanQuestion(); }

        /* ТАБЛИЦЫ */
        function renderMatrix() {
            const container = document.getElementById('matrix-container'); container.innerHTML = '';
            tablesData.forEach(table => {
                const tTitle = document.createElement('div'); tTitle.className = 'section-title'; tTitle.innerText = cleanText(table.section); container.appendChild(tTitle);
                table.data.forEach(row => {
                    const rDiv = document.createElement('div'); rDiv.className = 'matrix-row';
                    const sSpan = document.createElement('span'); sSpan.className = 'matrix-step'; sSpan.innerText = cleanText(row.s); rDiv.appendChild(sSpan);
                    const hDiv = document.createElement('div'); hDiv.className = 'matrix-hidden'; hDiv.innerText = 'Кликни, чтобы вспомнить...';
                    hDiv.onclick = () => { hDiv.innerText = cleanText(row.v); hDiv.classList.add('revealed'); };
                    rDiv.appendChild(hDiv); container.appendChild(rDiv);
                });
            });
        }

        /* ЧАТ-АССИСТЕНТ */
        function toggleChat() {
            document.getElementById('chat-panel').classList.toggle('open');
        }

        function buildKnowledgeBase() {
            let kb = "ВОПРОСЫ И ОТВЕТЫ ИЗ ТРЕНАЖЁРА:\n";
            database.forEach(item => {
                kb += "- В: " + cleanText(item.q) + " О: " + cleanText(item.a) + (item.t ? " Теория: " + cleanText(item.t) : "") + "\n";
            });
            kb += "\nТАБЛИЦЫ:\n";
            tablesData.forEach(table => {
                kb += cleanText(table.section) + ":\n";
                table.data.forEach(row => { kb += "  " + cleanText(row.s) + " — " + cleanText(row.v) + "\n"; });
            });
            return kb;
        }

        let chatHistory = [];

        // ⚙️ Вставьте сюда URL вашего Cloudflare Worker (см. инструкцию), например:
        // "https://my-alabuga-proxy.username.workers.dev"
        const PROXY_URL = "ВАШ_WORKER_URL_СЮДА";

        async function sendChatMessage() {
            const input = document.getElementById('chat-input');
            const text = input.value.trim();
            if (!text) return;
            input.value = '';
            const messagesEl = document.getElementById('chat-messages');

            const userDiv = document.createElement('div'); userDiv.className = 'chat-msg user'; userDiv.innerText = text;
            messagesEl.appendChild(userDiv);

            const loadingDiv = document.createElement('div'); loadingDiv.className = 'chat-msg bot loading'; loadingDiv.innerText = 'Думаю...';
            messagesEl.appendChild(loadingDiv);
            messagesEl.scrollTop = messagesEl.scrollHeight;

            chatHistory.push({ role: 'user', content: text });

            if (!PROXY_URL || PROXY_URL === "ВАШ_WORKER_URL_СЮДА") {
                loadingDiv.remove();
                const errDiv = document.createElement('div'); errDiv.className = 'chat-msg bot'; errDiv.innerText = 'Чат не настроен: вставьте адрес вашего Worker-прокси в переменную PROXY_URL в коде страницы (см. инструкцию).';
                messagesEl.appendChild(errDiv);
                messagesEl.scrollTop = messagesEl.scrollHeight;
                return;
            }

            try {
                const systemPrompt = "Ты — ассистент по корпоративной теории ОЭЗ Алабуга внутри обучающего тренажёра. " +
                    "Отвечай ТОЛЬКО на основе базы знаний ниже, кратко и по-русски, без выдумывания фактов, которых там нет. " +
                    "Если ответа нет в базе — честно скажи, что не нашёл это в материалах тренажёра.\n\n" + buildKnowledgeBase();

                const response = await fetch(PROXY_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        model: "claude-sonnet-4-6",
                        max_tokens: 1000,
                        system: systemPrompt,
                        messages: chatHistory
                    })
                });
                const data = await response.json();
                const replyText = (data.content || []).map(b => b.text || '').join('\n').trim() || 'Не удалось получить ответ.';
                loadingDiv.remove();
                const botDiv = document.createElement('div'); botDiv.className = 'chat-msg bot'; botDiv.innerText = replyText;
                messagesEl.appendChild(botDiv);
                chatHistory.push({ role: 'assistant', content: replyText });
            } catch (e) {
                loadingDiv.remove();
                const errDiv = document.createElement('div'); errDiv.className = 'chat-msg bot'; errDiv.innerText = 'Ошибка соединения с ассистентом. Проверьте, что Worker-прокси запущен и URL указан верно.';
                messagesEl.appendChild(errDiv);
            }
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        window.onload = () => { updateCard(); };
    </script>
</body>
</html>
